# ────────────────────────────────────────────────────────────────────────────────
# SYNTRA — Environment Variables Reference
# Copy this file to .env and fill in your values before running Docker Compose.
# NEVER commit your actual .env file to version control.
# ────────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Password for the PostgreSQL database.
# The full DATABASE_URL is built automatically by Docker Compose using this.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=replace_with_strong_password_here

# ── JWT / Session ─────────────────────────────────────────────────────────────
# Secret used to sign JWT auth tokens. Must be long and random.
# Generate: openssl rand -base64 64
SESSION_SECRET=replace_with_long_random_string_here

# ── App Public URL ─────────────────────────────────────────────────────────────
# The public HTTPS URL where SYNTRA is hosted (no trailing slash).
# Used to build password-reset links in emails sent to users.
# Without this, password-reset emails will contain a broken localhost URL.
# Example: https://app.yourdomain.com
APP_BASE_URL=https://app.yourdomain.com

# ── Contact Form SMTP ─────────────────────────────────────────────────────────
# SMTP credentials used to send landing-page enquiry emails.
# Enquiries are forwarded to CONTACT_EMAIL_TO.
# Note: per-company SMTP for staff emails (invitations, password resets) is
# configured inside the app by each company admin, not here.
CONTACT_SMTP_HOST=mail.cyberslide.net
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=support@madeat2am.in
CONTACT_SMTP_PASS=your_smtp_password_here
CONTACT_EMAIL_TO=chris@madeat2am.in
CONTACT_EMAIL_FROM=SYNTRA Enquiries <support@madeat2am.in>

# ── Optional Settings ─────────────────────────────────────────────────────────
# Log verbosity: "debug" | "info" (default) | "warn" | "error"
# LOG_LEVEL=info

# Set to "false" only if a company's SMTP server uses a self-signed TLS cert.
# Leave unset or "true" in all normal deployments.
# SMTP_REJECT_UNAUTHORIZED=true
