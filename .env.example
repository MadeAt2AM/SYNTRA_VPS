# ────────────────────────────────────────────────────────────────────────────────
# SYNTRA — Environment Variables Reference
# Copy this file to .env and fill in your values before running Docker Compose.
# NEVER commit your actual .env file to version control.
# ────────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Password for the PostgreSQL database.
# The DATABASE_URL is built automatically by Docker Compose using this password.
POSTGRES_PASSWORD=replace_with_strong_password_here

# ── JWT / Session ─────────────────────────────────────────────────────────────
# Secret used to sign JWT auth tokens. Must be long and random.
# Generate one: openssl rand -base64 64
SESSION_SECRET=replace_with_long_random_string_here

# ── Contact Form SMTP ─────────────────────────────────────────────────────────
# SMTP credentials used to send landing-page enquiry emails.
# Enquiries are forwarded to CONTACT_EMAIL_TO.
CONTACT_SMTP_HOST=mail.cyberslide.net
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=support@madeat2am.in
CONTACT_SMTP_PASS=your_smtp_password_here
CONTACT_EMAIL_TO=chris@madeat2am.in
CONTACT_EMAIL_FROM=SYNTRA Enquiries <support@madeat2am.in>

# ── Optional: SSL / Reverse Proxy ────────────────────────────────────────────
# If you put Caddy or another reverse proxy in front, these aren't needed here.
# Set REPLIT_DEV_DOMAIN only when running in Replit (auto-set by the platform).
# REPLIT_DEV_DOMAIN=your-repl.replit.dev
