# ─── Stage 1: Builder ─────────────────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@10 --activate

# Workspace config
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json tsconfig.json ./

# Package manifests for every workspace package
COPY lib/db/package.json                    ./lib/db/package.json
COPY lib/db/tsconfig.json                   ./lib/db/tsconfig.json
COPY lib/api-zod/package.json               ./lib/api-zod/package.json
COPY lib/api-zod/tsconfig.json              ./lib/api-zod/tsconfig.json
COPY lib/api-client-react/package.json      ./lib/api-client-react/package.json
COPY lib/api-client-react/tsconfig.json     ./lib/api-client-react/tsconfig.json
COPY lib/api-spec/package.json              ./lib/api-spec/package.json
COPY artifacts/web-app/package.json         ./artifacts/web-app/package.json
COPY artifacts/web-app/tsconfig.json        ./artifacts/web-app/tsconfig.json

RUN pnpm install --frozen-lockfile

# Source code
COPY lib/ ./lib/
COPY artifacts/web-app/ ./artifacts/web-app/

# Build the React SPA (BASE_PATH=/ so it works at nginx root)
ENV BASE_PATH=/
ENV NODE_ENV=production
RUN pnpm --filter @workspace/web-app run build

# ─── Stage 2: Nginx static server ─────────────────────────────────────────────
FROM nginx:1.27-alpine AS runner

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy our nginx config
COPY nginx/nginx.conf /etc/nginx/conf.d/syntra.conf

# Copy built SPA files
COPY --from=builder /workspace/artifacts/web-app/dist/public /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost/index.html || exit 1
